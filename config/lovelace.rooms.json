                },
                {
                  "entity": "sensor.knob_genre_override",
                  "name": "Genre Override"
                },
                {
                  "entity": "input_select.knob_genre",
                  "name": "Genre Selector"
                }
              ]
            },
            {
              "type": "horizontal-stack",
              "cards": [
                {
                  "type": "button",
                  "name": "Set Genre",
                  "icon": "mdi:music",
                  "tap_action": {
                    "action": "call-service",
                    "service": "script.knob_set_genre_from_select"
                  }
                },
                {
                  "type": "button",
                  "name": "Clear Genre",
                  "icon": "mdi:music-off",
                  "tap_action": {
                    "action": "call-service",
                    "service": "rest_command.knob_clear_genre"
                  }
                }
              ]
            }
          ]
        },
        {
          "title": "Hackitorium",
          "path": "hackitorium",
          "icon": "mdi:account-tie",
          "cards": [
            {
              "type": "entities",
              "title": "Power",
              "entities": [
                {
                  "entity": "switch.hackitorium_sw1_3rd_reality_zigbee",
                  "name": "Hackitorium SW1"
                },
                {
                  "entity": "sensor.hackitorium_sw1_3rd_reality_zigbee_power",
                  "name": "Power (W)"
                },
                {
                  "entity": "sensor.hackitorium_sw1_3rd_reality_zigbee_voltage",
                  "name": "Voltage"
                },
                {
                  "entity": "sensor.hackitorium_sw1_3rd_reality_zigbee_current",
                  "name": "Current"
                },
                {
                  "entity": "switch.flaschentaschen_socket_1",
                  "name": "FlaschenTaschen Power"
                }
              ]
            },
            {
              "type": "vertical-stack",
              "cards": [
                {
                  "type": "entities",
                  "title": "FlaschenTaschen",
                  "entities": [
                    {
                      "entity": "input_text.ft_message",
                      "name": "Message"
                    },
                    {
                      "entity": "input_select.ft_text_color",
                      "name": "Color"
                    }
                  ]
                },
                {
                  "type": "horizontal-stack",
                  "cards": [
                    {
                      "type": "button",
                      "name": "Send Message",
                      "icon": "mdi:send",
                      "tap_action": {
                        "action": "call-service",
                        "service": "script.ft_send_message"
                      }
                    },
                    {
                      "type": "button",
                      "name": "Clear Display",
                      "icon": "mdi:close-circle-outline",
                      "tap_action": {
                        "action": "call-service",
                        "service": "rest_command.ft_clear",
                        "service_data": {
                          "layer": 5
                        }
                      }
                    }
                  ]
                }
              ]
            },
            {
              "type": "vertical-stack",
              "cards": [
                {
                  "type": "entities",
                  "title": "Animations",
                  "entities": [
                    {
                      "entity": "input_select.ft_animation",
                      "name": "Animation"
                    }
                  ]
                },
                {
                  "type": "button",
                  "name": "Launch Animation",
                  "icon": "mdi:animation-play",
                  "tap_action": {
                    "action": "call-service",
                    "service": "script.ft_launch_animation"
                  }
                }
              ]
            },
            {
              "type": "markdown",
              "title": "Zikzak Streams",
              "content": "{% set src = state_attr('sensor.zikzak_icecast', 'source') %}\n{% if src %}\n{% for s in src %}\n**{{ s.listenurl.split('/')[-1] }}** \u2014 {{ s.listeners }} listeners  \n{{ s.title }}  \n\n{% endfor %}\n{% else %}*No streams*{% endif %}"
            }
          ]
        },
        {
          "title": "Electronics Lab",
          "path": "electronics-lab",
          "icon": "mdi:flask",
          "cards": [
            {
              "type": "glance",
              "title": "Environment",
              "entities": [
                {
                  "entity": "sensor.beyla_temp_humidity_sensor_sonoff_zigbee_temperature",
                  "name": "Temperature"
                },
                {
                  "entity": "sensor.beyla_temp_humidity_sensor_sonoff_zigbee_humidity",
                  "name": "Humidity"
                },
                {
                  "entity": "sensor.beyla_temp_humidity_sensor_sonoff_zigbee_battery",
                  "name": "Battery"
                }
              ]
            }
          ]
        }
      ]
    }
  }
}