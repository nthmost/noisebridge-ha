            {
              "type": "horizontal-stack",
              "cards": [
                {
                  "type": "button",
                  "name": "RNA Lounge",
                  "icon": "mdi:speaker",
                  "tap_action": {
                    "action": "navigate",
                    "navigation_path": "/rooms/rna-lounge"
                  }
                },
                {
                  "type": "button",
                  "name": "Hackitorium",
                  "icon": "mdi:account-tie",
                  "tap_action": {
                    "action": "navigate",
                    "navigation_path": "/rooms/hackitorium"
                  }
                },
                {
                  "type": "button",
                  "name": "Electronics Lab",
                  "icon": "mdi:flask",
                  "tap_action": {
                    "action": "navigate",
                    "navigation_path": "/rooms/electronics-lab"
                  }
                }
              ]
            }
          ]
        },
        {
          "title": "RNA Lounge",
          "path": "rna-lounge",
          "icon": "mdi:speaker",
          "cards": [
            {
              "type": "entities",
              "title": "Switches",
              "entities": [
                {
                  "entity": "switch.mini_smart_plug_socket_1",
                  "name": "Beyla Lights"
                },
                {
                  "entity": "switch.rna_sw1_3rd_reality_zigbee",
                  "name": "RNA SW1"
                },
                {
                  "entity": "switch.rna_sw2_3rd_reality_zigbee",
                  "name": "RNA SW2"
                }
              ]
            },
            {
              "type": "entities",
              "title": "KNOB Radio",
              "entities": [
                {
                  "entity": "sensor.knob_now_playing",
